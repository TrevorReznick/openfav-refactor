---
import type { Contact as Props } from '../../types'

import BaseLayout from '../../layouts/test/MyLayout.astro'
import SignUpForm from './my-form.astro'
import Wrapper from '../base/Wrapper.astro'

const {
  title = await Astro.slots.render('title'),
  subtitle = await Astro.slots.render('subtitle'),
  tagline = await Astro.slots.render('tagline'),
  inputs,
  disclaimer,
  button,
  description,

  id,
  isDark = false,
  classes = {},
  bg = await Astro.slots.render('bg'),
} = Astro.props;
---

<BaseLayout>
  <Wrapper id={id} isDark={isDark} containerClass={`max-w-7xl mx-auto ${classes?.container ?? ''}`} bg={bg}>
    {
      inputs && (
        <div class="flex flex-col max-w-xl mx-auto rounded-lg backdrop-blur border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900 shadow p-4 sm:p-6 lg:p-8 w-full">
          <SignUpForm inputs={inputs} disclaimer={disclaimer} button={button} description={description} />
        </div>
      )
    }
  </Wrapper>
</BaseLayout>