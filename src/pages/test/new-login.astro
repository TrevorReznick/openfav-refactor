---
import BaseLayout from '../../layouts/Base.astro'
import HeadlineComponent from '../../components/test-component/MyComponent.astro'
import SignUpComponent from '../../components/test-form/RefactorFormContainerComponent.astro'
import HeroText from '../../components/base/HeroText.astro'

---

<BaseLayout>
    <SignUpComponent 
        id="form"
        subtitle="Insert your credentials or connect with belows providers"
        inputs={[
           {
                type: 'email',
                name: 'email',
                label: 'Email',
            },
            {
                type: 'password',
                name: 'password',
                label: 'Password',
            },
        ]}
        disclaimer={{
            label:
              'By submitting this contact form, you acknowledge and agree to the collection of your personal information.',
        }}
        description="Our support team typically responds within 24 business hours."
    />  
</BaseLayout>